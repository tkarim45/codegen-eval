{
  "id": "binary_search",
  "title": "Binary search",
  "description": "Write binary_search(arr, target) that returns the index of target in the sorted list arr, or -1 if absent.",
  "function_name": "binary_search",
  "signature": "def binary_search(arr: list[int], target: int) -> int:",
  "constraints": [
    "arr is sorted ascending and may be empty.",
    "Return -1 when the target is not present.",
    "Must find targets at index 0 and at the last index."
  ],
  "edge_cases": [
    "empty list",
    "single-element list",
    "target at either end"
  ],
  "tests": [
    "assert binary_search([1, 3, 5, 7, 9], 5) == 2",
    "assert binary_search([1, 3, 5, 7, 9], 9) == 4",
    "assert binary_search([1, 3, 5, 7, 9], 4) == -1"
  ],
  "edge_tests": [
    "assert binary_search([], 1) == -1",
    "assert binary_search([5], 5) == 0",
    "assert binary_search([1, 2], 1) == 0"
  ],
  "perf_test": null,
  "properties": [
    "def property_check(fn, rng):",
    "    for _ in range(50):",
    "        arr = sorted(rng.sample(range(1000), rng.randint(0, 30)))",
    "        for t in arr:",
    "            assert arr[fn(arr, t)] == t",
    "        assert fn(arr, -1) == -1"
  ]
}
