{
  "id": "word_count",
  "title": "Word frequency counter",
  "description": "Write word_count(text) that returns a dict mapping each word to its count. Words are compared case-insensitively and surrounding punctuation is stripped.",
  "function_name": "word_count",
  "signature": "def word_count(text: str) -> dict[str, int]:",
  "constraints": [
    "Lowercase all words before counting.",
    "Strip surrounding punctuation (.,!?;:'\\\"()[]) from words.",
    "Return {} for empty or whitespace-only input."
  ],
  "edge_cases": [
    "empty string",
    "punctuation attached to words",
    "mixed case repeats"
  ],
  "tests": [
    "assert word_count('the cat and the hat') == {'the': 2, 'cat': 1, 'and': 1, 'hat': 1}",
    "assert word_count('a b a') == {'a': 2, 'b': 1}"
  ],
  "edge_tests": [
    "assert word_count('') == {}",
    "assert word_count('The dog. the dog!') == {'the': 2, 'dog': 2}",
    "assert word_count('   ') == {}"
  ],
  "perf_test": null,
  "properties": [
    "def property_check(fn, rng):",
    "    for _ in range(30):",
    "        words = [rng.choice(['ab', 'cd', 'ef']) for _ in range(rng.randint(0, 20))]",
    "        out = fn(' '.join(words))",
    "        assert sum(out.values()) == len(words)"
  ]
}
